### Core LLM routing
LLM_PROVIDER=auto
MODEL_NAME=gpt-4o-mini

### OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

### OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=Yolo Assistant

### Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

### Generic OpenAI-compatible provider/local proxy
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

### Telegram gateway
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

### Telegram webhook (optional)
TELEGRAM_USE_WEBHOOK=false
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_PATH=telegram
TELEGRAM_WEBHOOK_PORT=8080
TELEGRAM_WEBHOOK_LISTEN=0.0.0.0
TELEGRAM_WEBHOOK_SECRET_TOKEN=

### Discord gateway
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USER_IDS=

### Session and verbosity
SESSION_TIMEOUT_MINUTES=60
VERBOSE=false

### Upload/media processing
MAX_TELEGRAM_UPLOAD_BYTES=26214400
MAX_MEDIA_AI_BYTES=15728640
ENABLE_MEDIA_AI_PIPELINE=true
VISION_MODEL_NAME=gpt-4o-mini
TRANSCRIPTION_MODEL_NAME=gpt-4o-mini-transcribe

### Camoufox browser controls
# Uses `cloverlabs-camoufox` for per-context fingerprints and hardware spoofing.
CAMOUFOX_HEADLESS=true
CAMOUFOX_HUMANIZE=true
CAMOUFOX_BLOCK_IMAGES=false
CAMOUFOX_OS=windows,macos,linux

### Health endpoint
ENABLE_HEALTH_SERVER=true
HEALTH_SERVER_HOST=0.0.0.0
HEALTH_SERVER_PORT=8787
